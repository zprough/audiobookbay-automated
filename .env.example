# AudiobookBay Automated Configuration Example
# Copy this to .env and modify as needed

# AudiobookBay Settings
ABB_HOSTNAME=audiobookbay.lu
PAGE_LIMIT=5

# Download Client Settings
DOWNLOAD_CLIENT=qbittorrent
DL_HOST=192.168.1.100
DL_PORT=8080
DL_USERNAME=admin
DL_PASSWORD=adminpass
DL_CATEGORY=Audiobookbay-Audiobooks
SAVE_PATH_BASE=/downloads/audiobooks
DL_URL=

# Real-Debrid Settings
# Set DOWNLOAD_CLIENT=realdebrid to use these
RD_AUTH_MODE=oauth
RD_BASE_CLIENT_ID=X245A4XAIBGVM
RD_API_TOKEN=
RD_CLIENT_ID=
RD_CLIENT_SECRET=
RD_ACCESS_TOKEN=
RD_REFRESH_TOKEN=
RD_DOWNLOADS_DIR=/downloads
RD_MIN_FILE_SIZE_MB=25
RD_EXCLUDE_EXTENSIONS=.nfo,.txt,.exe,.iso,.lnk
RD_POLL_INTERVAL_SEC=5
RD_MAX_WAIT_SEC=900

# Navigation Link (optional)
NAV_LINK_NAME=Audiobookshelf
NAV_LINK_URL=http://192.168.1.100:13378

# Torznab API Settings
TORZNAB_API_KEY=your-secret-api-key-here
TORZNAB_TITLE=AudiobookBay Automated
TORZNAB_DESCRIPTION=AudiobookBay search via Torznab API

# Development Settings
FLASK_DEBUG=false
DEV_PORT=5079
